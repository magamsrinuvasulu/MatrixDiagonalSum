class Solution {
    public int diagonalSum(int[][] mat) {
        int sum=0;
        for(int i=0;i<mat.length;i++){
            sum+=mat[i][i];
        }
        int row=0,col=mat[0].length-1;
        for(int i=0;i<=mat.length-1;i++){
            if(row!=col){
                sum+=mat[row][col];
            }
            row++;
            col--;
        }
        return sum;
    }
}
